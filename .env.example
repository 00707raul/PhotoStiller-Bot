# Telegram API credentials from https://my.telegram.org/apps
API_ID=12345678
API_HASH=your_api_hash_here

# BotFather token for PhotoStiller_bot
BOT_TOKEN=your_new_photostiller_bot_token_here

# Your personal Telegram numeric user ID, from @userinfobot
OWNER_ID=123456789

# Optional settings
MAX_CONCURRENT_DOWNLOADS=5
PROGRESS_UPDATE_INTERVAL=50
MAX_RETRIES=3
DOWNLOAD_TIMEOUT=30
MAX_STORAGE_GB=10
MAX_IMAGE_MB=10
MAX_URLS_PER_MESSAGE=5
REQUEST_TIMEOUT=25
TELEGRAM_ZIP_LIMIT_MB=2000
PORT=10000
