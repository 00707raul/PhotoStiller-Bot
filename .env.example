# Required Telegram values
PYTHON_VERSION=3.11.9
API_ID=PASTE_API_ID_HERE
API_HASH=PASTE_API_HASH_HERE
BOT_TOKEN=PASTE_NEW_BOT_TOKEN_HERE
OWNER_ID=PASTE_OWNER_TELEGRAM_NUMERIC_ID_HERE
STRING_SESSION=PASTE_STRING_SESSION_HERE

# Public mode
BOT_NAME=PhotoSnatcher
PUBLIC_MODE=true
ALLOW_PRIVATE_LINKS_FOR_PUBLIC=false
MAX_ACTIVE_JOBS=0
ADMIN_IDS=

# Download limits
MAX_CONCURRENT_DOWNLOADS=5
PROGRESS_UPDATE_INTERVAL=50
PROGRESS_EDIT_INTERVAL_SECONDS=1
MAX_RETRIES=3
DOWNLOAD_TIMEOUT=30
MAX_STORAGE_GB=10
MAX_IMAGE_MB=50
MAX_URLS_PER_MESSAGE=5
REQUEST_TIMEOUT=25
TELEGRAM_ZIP_LIMIT_MB=2000
PUBLIC_MAX_PHOTOS_PER_JOB=0
OWNER_MAX_PHOTOS_PER_JOB=0
USER_DAILY_CHANNEL_LIMIT=0
USER_DAILY_DIRECT_LIMIT=0
MIN_SECONDS_BETWEEN_JOBS=0
SCAN_ALL_MESSAGES_FOR_REPORTS=true
KEEP_TEMP_FILES=false
DELETE_PROGRESS_MESSAGES=true

# Render website/dashboard
DASHBOARD_ENABLED=true
# Use true if you want https://your-render-url.onrender.com to show stats directly.
# Use false if you want a password page first.
DASHBOARD_PUBLIC=true
DASHBOARD_SECRET=photosnatcher_admin_2026_Raul_9xK72pQ
DASHBOARD_REFRESH_SECONDS=15
WEB_BASE_URL=https://your-render-service.onrender.com

# Privacy/storage control
STORE_DOWNLOAD_HISTORY=false
STORE_EVENT_DETAILS=false
